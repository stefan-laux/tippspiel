# --- SRF Tippspiel community to mirror (change this to track YOUR group) ---
SRF_COMMUNITY_URL=https://wmtippspiel.srf.ch/communities/32216

# --- Firebase Web config (safe to expose; rules enforce read-only) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin (server-only writes). Paste the service-account JSON on ONE line. ---
# Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# Alternatively use: FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
FIREBASE_SERVICE_ACCOUNT=

# --- Cron protection (any long random string; required in production) ---
CRON_SECRET=

# --- Optional fallbacks (NOT required: ESPN live data needs no key) ---
# FOOTBALL_API_KEY=
# LIVE_FEED_URL=
